venv/lib/python3.12/site-packages/edge_tts/data_classes.py\", line 38, in validate_string_param\n    raise TypeError(f\"{param_name} must be str\")\nTypeError: rate must be str"}],"details":{"status":"completed","exitCode":0,"durationMs":8,"aggregated":"^^^^^^^^^^^^^^^^^^^^\n  File \"/home/xzy0626/.openclaw/workspace/VoxBridge/src/tts.py\", line 182, in synthesize_segments\n    success = synthesize_speech(\n              ^^^^^^^^^^^^^^^^^^\n  File \"/home/xzy0626/.openclaw/workspace/VoxBridge/src/utils.py\", line 27, in wrapper\n    return func(*args, **kwargs)\n           ^^^^^^^^^^^^^^^^^^^^^\n  File \"/home/xzy0626/.openclaw/workspace/VoxBridge/src/tts.py\", line 102, in synthesize_speech\n    asyncio.run(_synthesize_with_rate(text, voice, 0, output_path))\n  File \"/usr/lib/python3.12/asyncio/runners.py\", line 194, in run\n    return runner.run(main)\n           ^^^^^^^^^^^^^^^^\n  File \"/usr/lib/python3.12/asyncio/runners.py\", line 118, in run\n    return self._loop.run_until_complete(task)\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"/usr/lib/python3.12/asyncio/base_events.py\", line 687, in run_until_complete\n    return future.result()\n           ^^^^^^^^^^^^^^^\n  File \"/home/xzy0626/.openclaw/workspace/VoxBridge/src/tts.py\", line 97, in _synthesize_with_rate\n    communicate = edge_tts.Communicate(text, voice, rate=rate)\n                  ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"/home/xzy0626/.openclaw/workspace/VoxBridge/venv/lib/python3.12/site-packages/edge_tts/communicate.py\", line 333, in __init__\n    self.tts_config = TTSConfig(voice, rate, volume, pitch, boundary)\n                      ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"<string>\", line 8, in __init__\n  File \"/home/xzy0626/.openclaw/workspace/VoxBridge/venv/lib/python3.12/site-packages/edge_tts/data_classes.py\", line 74, in __post_init__\n    self.validate_string_param(\"rate\", self.rate, r\"^[+-]\\d+%$\")\n  File \"/home/xzy0626/.openc