{"type":"message","id":"88010525","parentId":"e02c7419","timestamp":"2026-03-15T01:03:03.104Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在开始实施错误处理增强。我需要：\n\n1. 在 `src/pipeline.py` 中添加重试装饰器\n2. 在 `src/translate.py` 中优化术语映射\n3. 添加一个术语表配置文件\n4. 增加内存监控\n\n让我先创建一个重试装饰器和错误处理工具模块。","thinkingSignature":"reasoning"},{"type":"text","text":"### 步骤 2: 创建错误处理工具模块"},{"type":"toolCall","id":"call_4c2ff16c040f4b2e941866e3","name":"write","arguments":{"content":"\"\"\"\nUtility functions for robustness: retries, timeouts, disk checks\n\"\"\"\n\nimport time\nimport os\nfrom functools import wraps\nfrom typing import Callable, Any\n\ndef retry(max_attempts: int = 3, delay: float = 1.0, backoff: float = 2.0, exceptions: tuple = (Exception,)):\n    \"\"\"\n    Retry decorator with exponential backoff.\n\n    Args:\n        max_attempts: Maximum number of attempts\n        delay: Initial delay between retries (seconds)\n        backoff: Multiplier for delay after each failure\n        exceptions: Tuple of exceptions to catch\n    \"\"\"\n    def decorator(func: Callable) -> Callable:\n        @wraps(func)\n        def wrapper(*args, **kwargs) -> Any:\n            attempt = 0\n            current_delay = delay\n            while attempt < max_attempts:\n                try:\n                    return func(*args, **kwargs)\n                except exceptions as e:\n                    attempt += 1\n                    if attempt >= max_attempts:\n                        print(f\"❌ {func.__name__} failed after {max_attempts} attempts: {e}\")\n                        raise\n                    print(f\"⚠️  {func.__name__} failed (attempt {attempt}/{max_attempts}): {e}. Retrying in {current_delay:.1f}s...\")\n                    time.sleep(current_delay)\n                    current_delay *= backoff\n            return None  # Should not reach\n        return wrapper\n    return decorator\n\n\ndef check_disk_space(path: str, min_free_mb: int = 500) -> bool:\n    \"\"\"\n    Check if there's enough free disk space.\n\n    Args:\n        path: Directory to check\n        min_free_mb: Minimum required free space in MB\n\n    Returns:\n        bool: True if enough space\n    \"\"\"\n    try:\n        stat = os.statvfs(path)\n        free_bytes = stat.f_bavail * stat.f_frsize\n        free_mb = free_bytes / (1024 * 1024)\n        if free_mb < min_free_mb:\n            print(f\"❌ Insufficient disk space: {free_mb:.1f} MB free, need {min_free_mb} MB\")\n            return False\n        return True\n    except Exception as e:\n        print(f\"⚠️  Could not check disk space: {e}\")\n        return True  # Optimistic\n\n\ndef ensure_dir(path: str) -> bool:\n    \"\"\"\n    Create directory if it doesn't exist.\n\n    Returns:\n        bool: True if directory exists or created\n    \"\"\"\n    try:\n        os.makedirs(path, exist_ok=True)\n        return True\n    except Exception as e:\n        print(f\"❌ Failed to create directory {path}: {e}\")\n        return False\n\n\nif __name__ == '__main__':\n    # Quick test\n    print(\"Testing retry decorator...\")\n\n    @retry(max_attempts=3, delay=0.5)\n    def flaky_function(succeed: bool = False):\n        if not succeed:\n            raise ConnectionError(\"Simulated network error\")\n        return \"Success\"\n\n    try:\n        result = flaky_function(succeed=True)\n        print(f\"✅ Retry test passed: {result}\")\n    except Exception as e:\n        print(f\"❌ Retry test failed: {e}\")\n\n    print(\"\\nTesting disk space check...\")\n    ok = check_disk_space('.', min_free_mb=100)\n    print(f\"Disk space check: {'✅' if ok else '❌'}\")\n","file_path":"/home/xzy0626/.openclaw/workspace/VoxBridge-/src/utils.py"}}],"api":"openai-completions","provider":"openrouter","model":"stepfun/step-3.5-flash:free","usage":{"input":177225,"output":990,"cacheRead":0,"cacheWrite":0,"totalTokens":178215,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773536572186}}
