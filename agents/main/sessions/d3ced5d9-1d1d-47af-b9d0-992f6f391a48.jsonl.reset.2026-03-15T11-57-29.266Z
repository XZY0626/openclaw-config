{"type":"message","id":"ca75cb70","parentId":"09014f68","timestamp":"2026-03-14T23:36:19.438Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在实现主 pipeline（pipeline.py），这是核心协调器。需要：\n- 接受命令行参数\n- 顺序执行：提取音频 -> 转录 -> 翻译 -> TTS -> 合并\n- 参数配置（模型大小、TTS 声音等）\n- 错误处理和回退\n- 时间戳保持（用于音画同步）\n- 进度显示","thinkingSignature":"reasoning"},{"type":"text","text":"### 步骤 5: 实现完整 Pipeline（pipeline.py）"},{"type":"toolCall","id":"call_1c79707bc5cc4d0a9461d362","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nVoxBridge Pipeline - Complete workflow\n\nEnd-to-end processing: English video → Chinese voice video\n\"\"\"\n\nimport argparse\nimport sys\nimport os\nimport time\nfrom pathlib import Path\n\n# Add src to path\nBASE_DIR = Path(__file__).parent.absolute()\nsys.path.insert(0, str(BASE_DIR / 'src'))\n\nfrom video import extract_audio, replace_audio, get_video_info\nfrom transcribe import transcribe\nfrom translate import translate_segments\nfrom tts import synthesize_segments\n\n\ndef process_video(\n    input_path: str,\n    output_path: str,\n    whisper_model: str = 'base',\n    tts_voice: str = 'zh-CN-XiaoxiaoNeural',\n    keep_original_audio: bool = False\n) -> bool:\n    \"\"\"\n    Main pipeline: Convert English video to Chinese voice.\n\n    Args:\n        input_path: Input video file\n        output_path: Output video file (with Chinese audio)\n        whisper_model: faster-whisper model size\n        tts_voice: Edge-TTS voice name\n        keep_original_audio: If True, mix original audio (not implemented yet)\n\n    Returns:\n        bool: True if successful\n    \"\"\"\n    start_time = time.time()\n\n    # Check input exists\n    if not os.path.exists(input_path):\n        print(f\"❌ Input file not found: {input_path}\")\n        return False\n\n    # Get video info\n    print(\"📹 inspecting video...\")\n    video_info = get_video_info(input_path)\n    if video_info:\n        print(f\"   Duration: {video_info['duration']:.1f}s\")\n        print(f\"   Resolution: {video_info['width']}x{video_info['height']}\")\n        print(f\"   Video codec: {video_info['video_codec']}\")\n    else:\n        print(\"⚠️  Could not get video info, but continuing...\")\n\n    # Define temp paths\n    temp_dir = BASE_DIR / 'outputs' / 'temp'\n    os.makedirs(temp_dir, exist_ok=True)\n\n    audio_wav = str(temp_dir / 'original_audio.wav')\n    chinese_audio = str(temp_dir / 'chinese_audio.wav')\n    chinese_segments_dir = temp_dir / 'segments'\n\n    try:\n        # Step 1: Extract audio\n        print(\"\\n🔊 Step 1/4: Extracting audio from video...\")\n        if not extract_audio(input_path, audio_wav):\n            print(\"❌ Audio extraction failed\")\n            return False\n        print(f\"   ✅ Audio extracted: {os.path.getsize(audio_wav)/1024/1024:.1f} MB\")\n\n        # Step 2: Transcribe (English)\n        print(\"\\n🗣️  Step 2/4: Transcribing speech to text...\")\n        print(f\"   Model: faster-whisper-{whisper_model} (CPU mode)\")\n        full_text, segments = transcribe(audio_wav, model_size=whisper_model, language='en')\n        if not full_text:\n            print(\"❌ Transcription failed or empty\")\n            return False\n        print(f\"   ✅ Transcribed {len(segments)} segments\")\n        print(f\"   Text preview: {full_text[:100]}...\")\n\n        # Step 3: Translate to Chinese\n        print(\"\\n🌐 Step 3/4: Translating to Chinese...\")\n        segments_with_translation = translate_segments(segments, from_lang='en', to_lang='zh')\n        zh_full_text = ' '.join(s['text_zh'] for s in segments_with_translation if s.get('text_zh'))\n        print(f\"   ✅ Translated {len([s for s in segments_with_translation if s.get('text_zh')])} segments\")\n        print(f\"   Chinese preview: {zh_full_text[:100]}...\")\n\n        # Step 4: TTS synthesis\n        print(\"\\n🔉 Step 4/4: Synthesizing Chinese speech...\")\n        print(f\"   Voice: {tts_voice}\")\n        wav_files = synthesize_segments(segments_with_translation, chinese_segments_dir, voice=tts_voice)\n        if not wav_files:\n            print(\"❌ TTS synthesis failed (no output files)\")\n            return False\n        print(f\"   ✅ Generated {len(wav_files)} audio segments\")\n\n        # Concatenate all WAV segments into one file\n        print(\"   Concatenating audio segments...\")\n        concat_audio_segments(wav_files, chinese_audio)\n\n        # Step 5: Merge back to video (stream copy)\n        print(\"\\n🎬 Step 5/5: Muxing audio with video...\")\n        if not replace_audio(input_path, chinese_audio, output_path):\n            print(\"❌ Video muxing failed\")\n            return False\n\n        total_time = time.time() - start_time\n        print(f\"\\n✅ Pipeline complete! Output: {output_path}\")\n        print(f\"⏱️  Total time: {total_time:.1f}s\")\n\n        # Show output file info\n        if os.path.exists(output_path):\n            out_size = os.path.getsize(output_path) / 1024 / 1024\n            print(f\"   Output size: {out_size:.1f} MB\")\n\n        # Cleanup temp files? (Optionally keep for debug)\n        # cleanup_temp(temp_dir)\n\n        return True\n\n    except KeyboardInterrupt:\n        print(\"\\n⚠️  Pipeline interrupted by user\")\n        return False\n    except Exception as e:\n        print(f\"\\n❌ Pipeline error: {type(e).__name__}: {e}\")\n        import traceback\n        traceback.print_exc()\n        return False\n\n\ndef concat_audio_segments(wav_files: list, output_path: str):\n    \"\"\"\n    Concatenate multiple WAV files into one using ffmpeg concat demuxer.\n    All WAV files must have same format (16-bit PCM, 16kHz mono).\n    \"\"\"\n    try:\n        # Create file list for concat\n        list_file = Path(output_path).parent / 'concat_list.txt'\n        with open(list_file, 'w') as f:\n            for wav in wav_files:\n                # Escape single quotes in path\n                safe_path = str(wav).replace(\"'\", \"'\\\\''\")\n                f.write(f\"file '{safe_path}'\\n\")\n\n        # Use ffmpeg concat demuxer (no re-encode)\n        import subprocess\n        cmd = [\n            'ffmpeg', '-f', 'concat', '-safe', '0',\n            '-i', str(list_file),\n            '-acodec', 'pcm_s16le',  # Ensure output format\n            '-y',  # overwrite\n            output_path\n        ]\n        result = subprocess.run(cmd, capture_output=True, text=True)\n        if result.returncode != 0:\n            print(f\"❌ ffmpeg concat failed: {result.stderr}\")\n            # Fallback: copy first file only\n            import shutil\n            shutil.copy(wav_files[0], output_path)\n            print(\"⚠️  Using first segment only as fallback\")\n\n    except Exception as e:\n        print(f\"❌ Concatenation error: {e}\")\n        # Fallback: use first file\n        if wav_files:\n            import shutil\n            shutil.copy(wav_files[0], output_path)\n            print(\"⚠️  Using first segment only as fallback\")\n\n\ndef main():\n    parser = argparse.ArgumentParser(\n        description='VoxBridge: English video to Chinese voice translation'\n    )\n    parser.add_argument('--input', '-i', required=True, help='Input video file')\n    parser.add_argument('--output', '-o', required=True, help='Output video file')\n    parser.add_argument('--whisper-model', default='base',\n                        choices=['tiny', 'base', 'small', 'medium', 'large-v3'],\n                        help='faster-whisper model size')\n    parser.add_argument('--tts-voice', default='zh-CN-XiaoxiaoNeural',\n                        help='Edge-TTS voice name (e.g., zh-CN-XiaoxiaoNeural, zh-CN-YunxiNeural)')\n    parser.add_argument('--keep-original', action='store_true',\n                        help='Mix original audio with Chinese (not implemented)')\n\n    args = parser.parse_args()\n\n    print(\"=\" * 60)\n    print(\"🦞 VoxBridge Pipeline v0.1\")\n    print(\"=\" * 60)\n    print(f\"Input:  {args.input}\")\n    print(f\"Output: {args.output}\")\n    print(f\"Whisper: {args.whisper_model}\")\n    print(f\"TTS: {args.tts_voice}\")\n    print(\"=\" * 60)\n\n    success = process_video(\n        input_path=args.input,\n        output_path=args.output,\n        whisper_model=args.whisper_model,\n        tts_voice=args.tts_voice,\n        keep_original_audio=args.keep_original\n    )\n\n    if success:\n        print(\"\\n🎉 Pipeline completed successfully!\")\n        return 0\n    else:\n        print(\"\\n💥 Pipeline failed.\")\n        return 1\n\n\nif __name__ == '__main__':\n    sys.exit(main())\n","file_path":"/home/xzy0626/.openclaw/workspace/VoxBridge-/src/pipeline.py"}}],"api":"openai-completions","provider":"openrouter","model":"stepfun/step-3.5-flash:free","usage":{"input":104405,"output":2283,"cacheRead":0,"cacheWrite":0,"totalTokens":106688,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773531363823}}
