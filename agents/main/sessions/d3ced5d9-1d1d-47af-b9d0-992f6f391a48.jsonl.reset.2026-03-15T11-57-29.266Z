{"type":"message","id":"e2e3611e","parentId":"172b8028","timestamp":"2026-03-15T08:40:39.262Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Gradio installed successfully. Now let me create a simple Gradio UI for VoxBridge.","thinkingSignature":"reasoning"},{"type":"text","text":"Gradio 安装完成！现在创建 Web UI："},{"type":"toolCall","id":"6a1cf6de-16eb-4ca2-89e3-43100d74b62c","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nVoxBridge Web UI - Gradio interface for English video → Chinese voice translation\n\"\"\"\n\nimport gradio as gr\nimport os\nimport sys\nimport tempfile\nimport shutil\nfrom pathlib import Path\n\n# Add src to path\nBASE_DIR = Path(__file__).parent.absolute()\nsys.path.insert(0, str(BASE_DIR / 'src'))\n\nfrom pipeline import process_video\nfrom tts import get_available_voices_async\n\n# Available options\nWHISPER_MODELS = [\"tiny\", \"base\", \"small\"]\nTTS_VOICES = [\n    \"zh-CN-XiaoxiaoNeural\",  # 晓晓 (女声，温柔)\n    \"zh-CN-XiaoyiNeural\",    # 晓伊 (女声，活泼)\n    \"zh-CN-YunjianNeural\",   # 云健 (男声，新闻)\n    \"zh-CN-YunxiNeural\",     # 云希 (男声，阳光)\n    \"zh-CN-YunyangNeural\",   # 云扬 (男声，专业)\n]\n\nOUTPUT_DIR = BASE_DIR / 'outputs' / 'webui'\nOUTPUT_DIR.mkdir(parents=True, exist_ok=True)\n\n\ndef process_video_gradio(\n    video_file,\n    whisper_model,\n    tts_voice,\n    progress=gr.Progress()\n):\n    \"\"\"\n    Process video through VoxBridge pipeline.\n    \"\"\"\n    if video_file is None:\n        return None, \"❌ 请先上传视频文件\"\n\n    # Create output path\n    input_name = Path(video_file).stem\n    output_path = str(OUTPUT_DIR / f\"{input_name}_chinese.mp4\")\n\n    progress(0.1, desc=\"开始处理...\")\n\n    try:\n        # Run pipeline\n        success = process_video(\n            input_path=video_file,\n            output_path=output_path,\n            whisper_model=whisper_model,\n            tts_voice=tts_voice\n        )\n\n        if success and os.path.exists(output_path):\n            file_size = os.path.getsize(output_path) / 1024 / 1024\n            return output_path, f\"✅ 处理完成！\\n输出文件: {Path(output_path).name}\\n大小: {file_size:.1f} MB\"\n        else:\n            return None, \"❌ 处理失败，请检查日志\"\n\n    except Exception as e:\n        return None, f\"❌ 错误: {str(e)}\"\n\n\n# Build Gradio UI\nwith gr.Blocks(\n    title=\"🦞 VoxBridge - 英文视频转中文配音\",\n    theme=gr.themes.Soft()\n) as demo:\n\n    gr.Markdown(\"\"\"\n    # 🦞 VoxBridge\n    **英文视频 → 中文配音** | AI 驱动的语音翻译工具\n\n    上传英文视频，自动转录、翻译、合成中文语音，输出带中文配音的视频。\n    \"\"\")\n\n    with gr.Row():\n        with gr.Column(scale=1):\n            video_input = gr.Video(\n                label=\"上传英文视频\",\n                sources=[\"upload\"]\n            )\n\n            whisper_model = gr.Dropdown(\n                choices=WHISPER_MODELS,\n                value=\"tiny\",\n                label=\"Whisper 模型\",\n                info=\"tiny=快速, base=平衡, small=高精度\"\n            )\n\n            tts_voice = gr.Dropdown(\n                choices=TTS_VOICES,\n                value=\"zh-CN-XiaoxiaoNeural\",\n                label=\"中文语音\",\n                info=\"选择配音音色\"\n            )\n\n            process_btn = gr.Button(\n                \"🚀 开始处理\",\n                variant=\"primary\",\n                size=\"lg\"\n            )\n\n        with gr.Column(scale=1):\n            video_output = gr.Video(label=\"中文配音视频\")\n            status_output = gr.Textbox(\n                label=\"处理状态\",\n                lines=5,\n                interactive=False\n            )\n\n    # Event\n    process_btn.click(\n        fn=process_video_gradio,\n        inputs=[video_input, whisper_model, tts_voice],\n        outputs=[video_output, status_output]\n    )\n\n    gr.Markdown(\"\"\"\n    ---\n    **技术栈:** faster-whisper | MarianMT | edge-tts | ffmpeg\n    **项目:** [GitHub - VoxBridge](https://github.com/XZY0626/VoxBridge)\n    \"\"\")\n\n\nif __name__ == \"__main__\":\n    # Launch with Tailscale-accessible host\n    demo.launch(\n        server_name=\"0.0.0.0\",\n        server_port=7860,\n        share=False,\n        show_error=True\n    )\n","file_path":"/home/xzy0626/.openclaw/workspace/VoxBridge/app.py"}}],"api":"openai-completions","provider":"openrouter","model":"openrouter/hunter-alpha","usage":{"input":530,"output":1054,"cacheRead":196928,"cacheWrite":0,"totalTokens":198512,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773564013108}}
