{"type":"message","id":"63de8e76","parentId":"48d5fe41","timestamp":"2026-03-14T23:35:55.766Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"翻译模块需要：\n- 支持段落的批量翻译\n- 考虑到 argostranslate 可能有长度限制\n- 速度优化（批量）","thinkingSignature":"reasoning"},{"type":"text","text":"### 步骤 3: 完善翻译模块（translate.py）"},{"type":"toolCall","id":"call_57f9a28578ed479691c21756","name":"write","arguments":{"content":"\"\"\"\nTranslation using argostranslate (offline, no API)\n\"\"\"\n\nimport argostranslate.package\nimport argostranslate.translate\nfrom typing import List\n\ndef translate_text(text: str, from_lang='en', to_lang='zh') -> str:\n    \"\"\"\n    Translate text using argostranslate.\n\n    Args:\n        text: Input text string (can be long, will be split if needed)\n        from_lang: Source language code (default 'en')\n        to_lang: Target language code (default 'zh')\n\n    Returns:\n        Translated text string\n    \"\"\"\n    try:\n        # argostranslate has length limits for long texts\n        # If text is too long, split by sentences\n        if len(text) > 5000:\n            # Simple split by sentences (period) to avoid cutoff\n            sentences = text.replace('!', '.').replace('?', '.').split('.')\n            translated_sentences = []\n            for sent in sentences:\n                sent = sent.strip()\n                if len(sent) > 10:  # Skip tiny fragments\n                    try:\n                        tr = argostranslate.translate.translate(sent, from_lang, to_lang)\n                        translated_sentences.append(tr)\n                    except:\n                        translated_sentences.append(sent)  # Keep original if fail\n            return ' '.join(translated_sentences)\n        else:\n            return argostranslate.translate.translate(text, from_lang, to_lang)\n    except Exception as e:\n        print(f\"❌ Translation error: {e}\")\n        return text  # Return original on failure\n\n\ndef translate_segments(segments: List[dict], from_lang='en', to_lang='zh') -> List[dict]:\n    \"\"\"\n    Translate a list of segment dictionaries (from transcribe).\n    Adds 'text_zh' key to each segment.\n\n    Args:\n        segments: List of {'text': str, 'start': float, 'end': float}\n        from_lang: Source language\n        to_lang: Target language\n\n    Returns:\n        Same list with translated text in 'text_zh'\n    \"\"\"\n    for seg in segments:\n        original = seg['text'].strip()\n        if original:\n            translated = translate_text(original, from_lang, to_lang)\n            seg['text_zh'] = translated\n        else:\n            seg['text_zh'] = ''\n    return segments\n\n\nif __name__ == '__main__':\n    # Quick test\n    test_text = \"Hello, world! This is a test of the translation system.\"\n    result = translate_text(test_text, 'en', 'zh')\n    print(f\"Translation test:\")\n    print(f\"  EN: {test_text}\")\n    print(f\"  ZH: {result}\")\n","file_path":"/home/xzy0626/.openclaw/workspace/VoxBridge-/src/translate.py"}}],"api":"openai-completions","provider":"openrouter","model":"stepfun/step-3.5-flash:free","usage":{"input":102801,"output":732,"cacheRead":0,"cacheWrite":0,"totalTokens":103533,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773531348291}}
