{"type":"message","id":"71ebb218","parentId":"0fd05b8e","timestamp":"2026-03-14T23:36:03.784Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"TTS 模块需要：\n- edge-tts 是异步的，需要封装成同步接口\n- 支持批量生成（多个段落）\n- 合并音频文件\n- 错误重试机制\n- 音频质量优化","thinkingSignature":"reasoning"},{"type":"text","text":"### 步骤 4: 完善 TTS 模块（tts.py）"},{"type":"toolCall","id":"call_c69f8ba7f9bc4d0a9e31cfd2","name":"write","arguments":{"content":"\"\"\"\nText-to-speech using edge-tts (Microsoft Edge online service)\n\"\"\"\n\nimport asyncio\nimport os\nimport edge_tts\nfrom typing import List\n\ndef synthesize_speech(text: str, output_path: str, voice: str = 'zh-CN-XiaoxiaoNeural') -> bool:\n    \"\"\"\n    Generate Chinese speech from text using edge-tts.\n\n    Args:\n        text: Chinese text to synthesize (max 5000 chars recommended)\n        output_path: Output WAV file path\n        voice: Edge-TTS voice name (default: Chinese female)\n\n    Returns:\n        bool: True if successful\n    \"\"\"\n    try:\n        os.makedirs(os.path.dirname(output_path), exist_ok=True)\n\n        async def _synthesize():\n            communicate = edge_tts.Communicate(text, voice)\n            await communicate.save(output_path)\n\n        # Run async function in event loop\n        asyncio.run(_synthesize())\n\n        # Verify output file exists and has size\n        if os.path.exists(output_path) and os.path.getsize(output_path) > 1000:\n            return True\n        else:\n            print(f\"❌ TTS output invalid: {output_path}\")\n            return False\n\n    except Exception as e:\n        print(f\"❌ TTS error: {e}\")\n        return False\n\n\ndef synthesize_segments(segments: List[dict], output_dir: str, voice: str = 'zh-CN-XiaoxiaoNeural') -> List[str]:\n    \"\"\"\n    Synthesize speech for multiple text segments, saving each as separate WAV file.\n    Returns list of output file paths.\n\n    Args:\n        segments: List of {'text_zh': str, 'start': float, 'end': float, ...}\n        output_dir: Directory to store WAV files\n        voice: TTS voice\n\n    Returns:\n        List of WAV file paths (in order)\n    \"\"\"\n    os.makedirs(output_dir, exist_ok=True)\n    wav_files = []\n\n    for i, seg in enumerate(segments):\n        text = seg.get('text_zh', '').strip()\n        if not text:\n            continue\n\n        wav_path = os.path.join(output_dir, f'segment_{i:04d}.wav')\n        success = synthesize_speech(text, wav_path, voice)\n\n        if success:\n            wav_files.append(wav_path)\n        else:\n            print(f\"⚠️  Failed to synthesize segment {i}, skipping\")\n            # Optionally: use a placeholder beep or repeat previous\n\n    return wav_files\n\n\ndef get_available_voices():\n    \"\"\"\n    Get list of available Edge-TTS voices (async wrapper).\n    Note: This downloads voice list from Microsoft servers.\n    \"\"\"\n    async def _list():\n        return await edge_tts.list_voices()\n\n    voices = asyncio.run(_list())\n    return voices\n\n\nif __name__ == '__main__':\n    # Quick standalone test\n    test_text = \"你好，这是一个语音合成测试。\"\n    output = '../outputs/tts_test.wav'\n    success = synthesize_speech(test_text, output, voice='zh-CN-XiaoxiaoNeural')\n    if success:\n        print(f\"✅ TTS generated: {output}\")\n    else:\n        print(\"❌ TTS failed\")\n","file_path":"/home/xzy0626/.openclaw/workspace/VoxBridge-/src/tts.py"}}],"api":"openai-completions","provider":"openrouter","model":"stepfun/step-3.5-flash:free","usage":{"input":103534,"output":886,"cacheRead":0,"cacheWrite":0,"totalTokens":104420,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773531355818}}
