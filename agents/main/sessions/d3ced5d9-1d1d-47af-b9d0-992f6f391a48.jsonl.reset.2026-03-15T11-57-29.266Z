{"type":"message","id":"9e06e7c7","parentId":"de9ea269","timestamp":"2026-03-14T23:36:31.613Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在需要一个测试视频。我可以创建一个简单的测试方法：\n1. 让用户提供 sample video（通过某些方式）\n2. 或者使用一个公开的测试视频 URL（下载）\n3. 或者创建一个简单的合成测试（模拟音频）\n\n考虑到没有网络连接可能出现问题，我先实现一个基本的集成测试框架，然后提供使用说明。\n\n让我创建一个 test_pipeline.py 集成测试，并完善 requirements.txt（可能需要添加一些包）。\n\n同时，我需要检查是否有任何问题，特别是：\n- edge-tts 需要网络（如果网络不好，需要处理）\n- argostranslate 第一次使用会下载模型（可能慢）\n\n让我先写一个简单的集成测试。","thinkingSignature":"reasoning"},{"type":"text","text":"现在让我创建集成测试脚本和一个简单的示例（使用合成音频测试）："},{"type":"toolCall","id":"call_90a53024a6bd4d7fb6fcca45","name":"write","arguments":{"content":"\"\"\"\nEnd-to-end integration tests for VoxBridge pipeline\n\"\"\"\n\nimport unittest\nimport os\nimport sys\nimport tempfile\nfrom pathlib import Path\n\n# Add src to path\nBASE_DIR = Path(__file__).parent.absolute()\nsys.path.insert(0, str(BASE_DIR / '..' / 'src'))\n\nclass TestPipeline(unittest.TestCase):\n    \"\"\"Test the complete pipeline with synthetic audio.\"\"\"\n\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Create a test video with synthetic audio.\"\"\"\n        cls.test_dir = BASE_DIR / 'outputs' / 'test_run'\n        os.makedirs(cls.test_dir, exist_ok=True)\n\n        # Create a short test video (black screen with tone)\n        cls.test_video = str(cls.test_dir / 'input_test.mp4')\n        cls.output_video = str(cls.test_dir / 'output_test.mp4')\n\n        # Generate 5-second test audio using ffmpeg\n        test_audio = str(cls.test_dir / 'test_tone.wav')\n        cmd = [\n            'ffmpeg', '-f', 'lavfi', '-i', 'sine=frequency=440:duration=5',\n            '-ar', '16000', '-ac', '1', '-y', test_audio\n        ]\n        import subprocess\n        subprocess.run(cmd, capture_output=True)\n\n        # Create a simple MP4 with that audio (black video)\n        cmd2 = [\n            'ffmpeg', '-f', 'lavfi', '-i', 'color=c=black:s=320x240:d=5',\n            '-i', test_audio,\n            '-c:v', 'libx264', '-c:a', 'aac', '-y', cls.test_video\n        ]\n        subprocess.run(cmd2, capture_output=True)\n\n        cls.video_exists = os.path.exists(cls.test_video)\n        if not cls.video_exists:\n            print(\"⚠️  Could not create test video - ffmpeg may not support lavfi?\")\n\n    def test_01_video_creation(self):\n        \"\"\"Test that test video was created.\"\"\"\n        self.assertTrue(self.video_exists, \"Test video could not be created\")\n\n    def test_02_video_info(self):\n        \"\"\"Test video info extraction.\"\"\"\n        from video import get_video_info\n        info = get_video_info(self.test_video)\n        self.assertIsNotNone(info, \"Video info should not be None\")\n        self.assertGreater(info['duration'], 4, \"Video should be ~5 seconds\")\n\n    def test_03_audio_extraction(self):\n        \"\"\"Test audio extraction.\"\"\"\n        from video import extract_audio\n        audio_path = str(self.test_dir / 'extracted.wav')\n        result = extract_audio(self.test_video, audio_path)\n        self.assertTrue(result, \"Audio extraction should succeed\")\n        self.assertTrue(os.path.exists(audio_path), \"Extracted audio file should exist\")\n\n    def test_04_transcribe(self):\n        \"\"\"Test transcription (requires audio).\"\"\"\n        from transcribe import transcribe\n        audio_path = str(self.test_dir / 'extracted.wav')\n        if not os.path.exists(audio_path):\n            self.skipTest(\"No extracted audio (previous step failed)\")\n\n        text, segments = transcribe(audio_path, model_size='tiny', language='en')\n        # Tone doesn't produce speech, expect empty or very short\n        self.assertIsInstance(text, str, \"Transcribed text should be string\")\n        print(f\"\\n🔊 Transcription result: '{text[:50]}...' ({len(segments)} segments)\")\n\n    def test_05_translate(self):\n        \"\"\"Test translation.\"\"\"\n        from translate import translate_text, translate_segments\n        test_english = \"Hello world, this is a test.\"\n        zh = translate_text(test_english, 'en', 'zh')\n        self.assertIsInstance(zh, str, \"Translation should be string\")\n        self.assertGreater(len(zh), 0, \"Translation should not be empty\")\n        print(f\"\\n🌐 Translation: '{test_english}' → '{zh}'\")\n\n        # Test translate_segments\n        segments = [{'text': 'Hello world.', 'start': 0, 'end': 1}]\n        translated = translate_segments(segments)\n        self.assertIn('text_zh', translated[0], \"Segments should have text_zh key\")\n\n    def test_06_tts(self):\n        \"\"\"Test TTS synthesis.\"\"\"\n        from tts import synthesize_speech\n        test_zh = \"你好，测试。\"\n        wav_path = str(self.test_dir / 'tts_test.wav')\n        result = synthesize_speech(test_zh, wav_path)\n        self.assertTrue(result, \"TTS should succeed\")\n        self.assertTrue(os.path.exists(wav_path), \"TTS output should exist\")\n\n    def test_07_full_pipeline_short(self):\n        \"\"\"Test the complete pipeline with a tiny model.\"\"\"\n        from pipeline import process_video\n        # This is a full integration test - may take a while\n        output = str(self.test_dir / 'pipeline_output.mp4')\n\n        # Run with tiny model (fastest) and short test video\n        success = process_video(\n            input_path=self.test_video,\n            output_path=output,\n            whisper_model='tiny',\n            tts_voice='zh-CN-XiaoxiaoNeural'\n        )\n\n        if success:\n            self.assertTrue(os.path.exists(output), \"Output video should exist\")\n            # Check file size (should be > 10KB)\n            self.assertGreater(os.path.getsize(output), 10000, \"Output should be non-trivial\")\n        else:\n            self.fail(\"Pipeline did not complete successfully\")\n\nif __name__ == '__main__':\n    print(\"🧪 Running VoxBridge Integration Tests...\\n\")\n    unittest.main(verbosity=2)\n","file_path":"/home/xzy0626/.openclaw/workspace/VoxBridge-/tests/test_pipeline.py"}}],"api":"openai-completions","provider":"openrouter","model":"stepfun/step-3.5-flash:free","usage":{"input":106633,"output":1698,"cacheRead":0,"cacheWrite":0,"totalTokens":108331,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773531379485}}
