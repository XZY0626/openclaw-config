gments(segs)\nzh_text = ' '.join(s['text_zh'] for s in segs_zh if s.get('text_zh'))\nprint(f'   ✅ {len(segs_zh)} segments translated')\nprint(f'   Preview: {zh_text[:120]}...')\n\n# 5. TTS\nprint('🔉 Synthesizing speech (edge-tts)...')\nwav_files = synthesize_segments(segs_zh, str(temp_dir / 'wavs'))\nprint(f'   ✅ {len(wav_files)} audio files generated')\n\n# 6. Concatenate WAVs\nprint('🔗 Concatenating audio...')\nconcat_list = temp_dir / 'list.txt'\nwith open(concat_list, 'w') as f:\n    for w in wav_files:\n        f.write(f\"file '{w}'\\n\")\nfinal_audio = str(temp_dir / 'chinese_audio.wav')\nimport subprocess\ncmd = ['ffmpeg', '-f', 'concat', '-safe', '0', '-i', str(concat_list), '-acodec', 'pcm_s16le', '-y', final_audio]\nres = subprocess.run(cmd, capture_output=True, text=True)\nif res.returncode != 0:\n    print(f'❌ concat error: {res.stderr}')\n    raise SystemExit(1)\nprint(f'   ✅ Final audio: {os.path.getsize(final_audio)/1024:.0f} KB')\n\n# 7. Merge\nprint('🎬 Muxing video + audio...')\nok = replace_audio(input_video, final_audio, output_video)\nif not ok: raise SystemExit(1)\nprint(f'   ✅ Output: {os.path.getsize(output_video)/1024:.0f} KB')\n\nprint('='*60)\nprint('🎉 Pipeline complete! Demo ready.')\nprint('='*60)\nEOPIPE","name":"cd ~/.openclaw/workspace/VoxBridge-","tail":"'[Errno 101] Network is unreachable' thrown while requesting HEAD https://huggingface.co/Helsinki-NLP/opus-mt-en-zh/resolve/main/model.safetensors\nRetrying in 1s [Retry 1/5].\n","truncated":false},{"sessionId":"young-mist","status":"failed","startedAt":1773532206159,"endedAt":1773532891717,"runtimeMs":685558,"cwd":"/home/xzy0626/.openclaw/workspace","command":"cd ~/.openclaw/workspace/VoxBridge- && venv/bin/python3 src/pipeline.py --input samples/b90e47fa-fbd3-446e-9f8b-ce025e893a56.mp4 --output outputs/b90e47fa-chinese.mp4 --whisper-model tiny --tts-voice zh-CN-XiaoxiaoNeural 2>&1","name":"cd ~/.openclaw/workspace/VoxBridge-","tail":"2026-03-15 07:52:22 WARNING: Language en package 