{"type":"message","id":"a2518f2a","parentId":"516c922f","timestamp":"2026-03-15T01:03:15.759Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在更新 translate.py 添加术语表支持，并优化 MarianMT 的调用。同时添加重试机制。","thinkingSignature":"reasoning"},{"type":"text","text":"### 步骤 3: 增强 translate.py 添加术语表支持"},{"type":"toolCall","id":"call_c05832fcba0d4b8c8f727d7d","name":"read","arguments":{"file_path":"/home/xzy0626/.openclaw/workspace/VoxBridge-/src/translate.py"}},{"type":"toolCall","id":"call_71b1a379515442e1875e969d","name":"write","arguments":{"content":"\"\"\"\nTranslation using MarianMT (Hugging Face transformers) - with glossary support\n\"\"\"\n\nimport os\nfrom transformers import MarianTokenizer, MarianMTModel\nfrom typing import List, Dict\n\n# Set HF mirror to avoid network issues\nos.environ.setdefault('HF_ENDPOINT', 'https://hf-mirror.com')\nos.environ.setdefault('HF_HUB_DISABLE_TELEMETRY', 'true')\n\nMODEL_NAME = \"Helsinki-NLP/opus-mt-en-zh\"\n\n_translator = None\n_tokenizer = None\n\n# Glossary (term mapping) - can be loaded from external file\nGLOSSARY = {\n    # 示例术语，实际应从文件加载\n    # \"digital brains\": \"数字大脑\",\n    # \"AI\": \"人工智能\",\n    # \"machine learning\": \"机器学习\",\n}\n\n\ndef load_glossary(glossary_path: str = None) -> Dict[str, str]:\n    \"\"\"\n    Load glossary from a file (tab-separated: en\\tzh).\n\n    Args:\n        glossary_path: Path to glossary file (one term per line)\n\n    Returns:\n        dict: Mapping from English term to Chinese translation\n    \"\"\"\n    global GLOSSARY\n    if not glossary_path:\n        # Default glossary in project root\n        glossary_path = os.path.join(os.path.dirname(__file__), '..', 'glossary.txt')\n\n    if os.path.exists(glossary_path):\n        try:\n            with open(glossary_path, 'r', encoding='utf-8') as f:\n                for line in f:\n                    line = line.strip()\n                    if not line or line.startswith('#'):\n                        continue\n                    parts = line.split('\\t')\n                    if len(parts) >= 2:\n                        en, zh = parts[0].lower(), parts[1]\n                        GLOSSARY[en] = zh\n            print(f\"📖 Loaded glossary: {len(GLOSSARY)} terms\")\n        except Exception as e:\n            print(f\"⚠️  Failed to load glossary: {e}\")\n    return GLOSSARY\n\n\ndef apply_glossary(text: str) -> str:\n    \"\"\"\n    Replace terms in text according to glossary.\n    Case-insensitive matching, preserves original casing if possible.\n\n    Args:\n        text: English text to preprocess\n\n    Returns:\n        Text with glossary terms marked (uppercase) for translation model\n    \"\"\"\n    if not GLOSSARY:\n        return text\n\n    # Sort by length (longest first) to avoid partial matches\n    sorted_terms = sorted(GLOSSARY.keys(), key=len, reverse=True)\n    result = text\n    for term in sorted_terms:\n        if term in result.lower():\n            # Replace with uppercase version to hint translation model\n            # (MarianMT may preserve casing which helps produce correct term)\n            result = result.replace(term, term.upper())\n    return result\n\n\ndef load_model():\n    \"\"\"Lazy load MarianMT model and tokenizer.\"\"\"\n    global _translator, _tokenizer\n    if _translator is None or _tokenizer is None:\n        print(f\"📥 Loading MarianMT model: {MODEL_NAME}\")\n        _tokenizer = MarianTokenizer.from_pretrained(MODEL_NAME)\n        _translator = MarianMTModel.from_pretrained(MODEL_NAME)\n        print(\"✅ Model loaded\")\n    return _tokenizer, _translator\n\n\ndef translate_text(text: str, from_lang='en', to_lang='zh') -> str:\n    \"\"\"\n    Translate text using MarianMT with glossary support.\n\n    Args:\n        text: Input English text\n\n    Returns:\n        Translated Chinese text (or original if fails)\n    \"\"\"\n    if from_lang != 'en' or to_lang != 'zh':\n        return text\n\n    try:\n        tokenizer, model = load_model()\n    except Exception as e:\n        print(f\"❌ Failed to load MarianMT model: {e}\")\n        return text\n\n    try:\n        # Apply glossary preprocessing\n        text_processed = apply_glossary(text)\n\n        # Tokenize and translate\n        inputs = tokenizer(text_processed, return_tensors=\"pt\", padding=True, truncation=True, max_length=512)\n        translated = model.generate(**inputs)\n        result = tokenizer.decode(translated[0], skip_special_tokens=True)\n\n        # Post-process: convert any ALLCAPS terms back to glossary Chinese\n        # (Simple approach: if we recognize an uppercase term, replace its translation)\n        # For now, just return result - can be improved later\n        return result\n    except Exception as e:\n        print(f\"❌ Translation error: {e}\")\n        return text\n\n\ndef translate_segments(segments: List[dict], from_lang='en', to_lang='zh') -> List[dict]:\n    \"\"\"\n    Translate a list of segment dictionaries.\n    \"\"\"\n    for seg in segments:\n        original = seg['text'].strip()\n        if original:\n            translated = translate_text(original, from_lang, to_lang)\n            seg['text_zh'] = translated\n        else:\n            seg['text_zh'] = ''\n    return segments\n\n\nif __name__ == '__main__':\n    # Test\n    load_glossary()  # Try to load default glossary\n\n    test = \"Hello world, this is a test of the translation system with digital brains.\"\n    result = translate_text(test, 'en', 'zh')\n    print(f\"\\nTranslation:\")\n    print(f\"  EN: {test}\")\n    print(f\"  ZH: {result}\")\n","file_path":"/home/xzy0626/.openclaw/workspace/VoxBridge-/src/translate.py"}}],"api":"openai-completions","provider":"openrouter","model":"stepfun/step-3.5-flash:free","usage":{"input":178165,"output":1341,"cacheRead":0,"cacheWrite":0,"totalTokens":179506,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773536583150}}
{"type":"message","id":"0d8d6052","parentId":"a2518f2a","timestamp":"2026-03-15T01:03:15.771Z","message":{"role":"toolResult","toolCallId":"call_c05832fcba0d4b8c8f727d7d","toolName":"read","content":[{"type":"text","text":"\"\"\"\nTranslation using MarianMT (Hugging Face transformers) - with hf-mirror support\n\"\"\"\n\nimport os\nfrom transformers import MarianTokenizer, MarianMTModel\nfrom typing import List\n\n# Set HF mirror to avoid network issues\nos.environ.setdefault('HF_ENDPOINT', 'https://hf-mirror.com')\nos.environ.setdefault('HF_HUB_DISABLE_TELEMETRY', 'true')\n\nMODEL_NAME = \"Helsinki-NLP/opus-mt-en-zh\"\n\n_translator = None\n_tokenizer = None\n\ndef load_model():\n    \"\"\"Lazy load MarianMT model and tokenizer.\"\"\"\n    global _translator, _tokenizer\n    if _translator is None or _tokenizer is None:\n        print(f\"📥 Loading MarianMT model: {MODEL_NAME}\")\n        _tokenizer = MarianTokenizer.from_pretrained(MODEL_NAME)\n        _translator = MarianMTModel.from_pretrained(MODEL_NAME)\n        print(\"✅ Model loaded\")\n    return _tokenizer, _translator\n\ndef translate_text(text: str, from_lang='en', to_lang='zh') -> str:\n    \"\"\"\n    Translate text using MarianMT.\n    \"\"\"\n    if from_lang != 'en' or to_lang != 'zh':\n        return text  # Only support en→zh\n\n    try:\n        tokenizer, model = load_model()\n    except Exception as e:\n        print(f\"❌ Failed to load MarianMT model: {e}\")\n        return text\n\n    try:\n        inputs = tokenizer(text, return_tensors=\"pt\", padding=True, truncation=True, max_length=512)\n        translated = model.generate(**inputs)\n        result = tokenizer.decode(translated[0], skip_special_tokens=True)\n        return result\n    except Exception as e:\n        print(f\"❌ Translation error: {e}\")\n        return text\n\ndef translate_segments(segments: List[dict], from_lang='en', to_lang='zh') -> List[dict]:\n    \"\"\"\n    Translate a list of segment dictionaries.\n    \"\"\"\n    for seg in segments:\n        original = seg['text'].strip()\n        if original:\n            translated = translate_text(original, from_lang, to_lang)\n            seg['text_zh'] = translated\n        else:\n            seg['text_zh'] = ''\n    return segments\n\nif __name__ == '__main__':\n    test = \"Hello world, this is a test.\"\n    result = translate_text(test, 'en', 'zh')\n    print(f\"Translation: '{test}' → '{result}'\")\n"}],"isError":false,"timestamp":1773536595769}}
